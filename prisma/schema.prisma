// Prisma schema for DasPay logistics platform
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Lead/contact form submissions
model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  service   String?
  message   String
  ip        String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transportType String?
  fromStation   String?
  toStation     String?
  fromStationId Int?
  fromStationRef Station? @relation("LeadFromStation", fields: [fromStationId], references: [id])
  toStationId   Int?
  toStationRef   Station? @relation("LeadToStation", fields: [toStationId], references: [id])
  documents     Json?    @default("[]")
  assignedToId  Int?
  assignee      User?    @relation("UserLeads", fields: [assignedToId], references: [id])
  tasks         Task[]

  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([fromStationId])
  @@index([toStationId])
}

/// Tracking queries for analytics
model TrackingQuery {
  id           Int      @id @default(autoincrement())
  trackingCode String
  ip           String?
  found        Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([trackingCode])
  @@index([createdAt])
}

/// Blog posts for content management
model BlogPost {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  titleUz     String
  titleRu     String
  titleEn     String
  contentUz   String
  contentRu   String
  contentEn   String
  excerptUz   String?
  excerptRu   String?
  excerptEn   String?
  image       String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
}

/// Shipment tracking data (mock data for demo)
model Shipment {
  id           Int      @id @default(autoincrement())
  trackingCode String   @unique
  senderName   String
  receiverName String
  origin       String
  destination  String
  status       String   @default("pending")
  weight       Float?
  description  String?
  events       Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clientPhone  String?
  client       Client?  @relation(fields: [clientPhone], references: [phone])
  
  originLat       Float?
  originLng       Float?
  destinationLat  Float?
  destinationLng  Float?
  currentLat      Float?
  currentLng      Float?
  routeSegments   Json     @default("[]")

  /// 'road' | 'rail' | 'air' | 'sea' — affects ETA avg speed
  transportMode   String?
  /// Total route distance in km (from OSRM or manual)
  distanceKm      Float?
  /// Projected delivery date/time
  etaAt           DateTime?
  /// Revenue captured on the shipment (from invoices or manual)
  revenue         Float    @default(0)
  /// Internal cost (carriers, fuel, customs) for margin calc
  cost            Float    @default(0)
  currency        String   @default("USD")

  createdById     Int?
  createdBy       User?    @relation("ShipmentsCreated", fields: [createdById], references: [id])
  invoices        Invoice[]
  feedback        Feedback?

  @@index([trackingCode])
  @@index([status])
  @@index([createdById])
  @@index([clientPhone])
}

/// Rate limiting for forms
model RateLimit {
  id        Int      @id @default(autoincrement())
  ip        String
  endpoint  String
  count     Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([ip, endpoint])
  @@index([windowStart])
}

/// Contract agreements with client companies
model Contract {
  id              Int      @id @default(autoincrement())
  /// Auto-incrementing contract number (e.g. 1, 2, 3...)
  contractNumber  Int      @unique @default(autoincrement())
  /// Date the contract was signed (e.g. "14 апрель 2026г")
  contractDate    String
  /// Client company name
  companyName     String
  /// Company director full name
  companyDirector String
  /// Company address
  companyAddress  String
  /// Company INN (9-digit, xxx xxx xxx)
  companyInn      String
  /// Serving bank name
  companyBank     String
  /// Bank MFO (5-digit)
  bankMfo         String
  /// Bank INN (9-digit)
  bankInn         String
  /// Bank account number
  bankNum         String
  /// Currency: UZS or USD
  bankCurrency    String   @default("UZS")
  /// Whether correspondent bank exists
  hasCorrespondent Boolean  @default(false)
  /// Correspondent bank name (optional)
  bankCorrName    String?
  /// Correspondent bank address (optional)
  bankCorrAddress String?
  /// Correspondent bank SWIFT code (optional)
  bankCorrSwift   String?
  /// Contract status
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        Invoice[]

  @@index([contractNumber])
  @@index([status])
  @@index([createdAt])
}

/// Freight tariff catalog — used by calculator and quick quotes
model Tariff {
  id             Int      @id @default(autoincrement())
  /// Human label e.g. "Xitoy → Toshkent (Avto)"
  name           String
  originCountry  String
  originCity     String?
  destCountry    String
  destCity       String?
  /// truck | train
  mode           String   @default("train")
  /// Price per ton in `currency`
  pricePerKg     Float    @default(0)
  /// Fixed baseline fee added to every shipment on this lane
  baseFee        Float    @default(0)
  /// Minimum billable weight (ton)
  minWeight      Float    @default(0)
  /// USD / UZS / RUB
  currency       String   @default("USD")
  /// Estimated transit time in days
  transitDays    Int?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([originCountry, destCountry])
  @@index([mode])
  @@index([active])
}

/// Invoice for a shipment / client
model Invoice {
  id           Int      @id @default(autoincrement())
  number       String   @unique
  issueDate    DateTime @default(now())
  dueDate      DateTime

  shipmentId   Int?
  shipment     Shipment? @relation(fields: [shipmentId], references: [id])

  clientPhone  String?
  client       Client?   @relation(fields: [clientPhone], references: [phone])

  contractId   Int?
  contract     Contract? @relation(fields: [contractId], references: [id])

  /// [{ description, quantity, unitPrice, total }]
  items        Json     @default("[]")
  subtotal     Float    @default(0)
  taxRate      Float    @default(0)
  tax          Float    @default(0)
  total        Float    @default(0)
  paidAmount   Float    @default(0)
  currency     String   @default("USD")

  /// draft, sent, paid, overdue, cancelled
  status       String   @default("draft")
  notes        String?

  sentAt       DateTime?
  paidAt       DateTime?

  createdById  Int?
  createdBy    User?    @relation("InvoicesCreated", fields: [createdById], references: [id])
  payments     Payment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([clientPhone])
  @@index([shipmentId])
  @@index([number])
}

/// Admin/Employee users
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN") // SUPERADMIN or ADMIN
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  actions   UserAction[]
  leads     Lead[]       @relation("UserLeads")
  tasksCreated  Task[] @relation("TasksCreated")
  tasksAssigned Task[] @relation("TasksAssigned")
  shipmentsCreated Shipment[] @relation("ShipmentsCreated")
  invoicesCreated Invoice[]  @relation("InvoicesCreated")

  @@index([username])
}

/// Task management for Employees
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  leadId      Int?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  assignedById Int
  assignedBy   User    @relation("TasksCreated", fields: [assignedById], references: [id])
  assignedToId Int
  assignedTo   User    @relation("TasksAssigned", fields: [assignedToId], references: [id])
  deadline     DateTime
  status       String  @default("pending")  // pending, in_progress, completed, overdue
  priority     String  @default("medium")   // low, medium, high, urgent
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([assignedToId])
  @@index([deadline])
}

/// Registered clients
model Client {
  id         Int        @id @default(autoincrement())
  phone      String     @unique
  telegramId String?    @unique
  name       String?
  otpCode    String?
  otpExpiry  DateTime?
  password   String?
  createdAt  DateTime   @default(now())

  /// Notification preferences
  notifyStatusChange  Boolean @default(true)
  notifyEta           Boolean @default(true)
  notifyInvoices      Boolean @default(true)
  notifyPromo         Boolean @default(false)
  notifyEmail         String?

  shipments  Shipment[]
  invoices   Invoice[]
  addresses  ClientAddress[]

  @@index([phone])
  @@index([telegramId])
}

/// Saved sender/receiver addresses for a client (address book)
model ClientAddress {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// 'sender' or 'receiver'
  role        String
  label       String?
  fullName    String
  phone       String
  country     String
  city        String?
  address     String?
  notes       String?
  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, role])
}

/// Online payment attempts for invoices (Click, Payme, etc.)
model Payment {
  id          Int       @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  /// 'click' | 'payme' | 'manual'
  provider    String
  /// External transaction id from gateway
  externalId  String?   @unique
  amount      Float
  currency    String    @default("UZS")
  /// 'pending' | 'paid' | 'cancelled' | 'failed'
  status      String    @default("pending")
  /// Payload returned by gateway webhook (for audit)
  rawPayload  Json?

  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([invoiceId])
  @@index([status])
  @@index([provider, externalId])
}

/// Post-delivery NPS feedback tied to a shipment
model Feedback {
  id          Int      @id @default(autoincrement())
  shipmentId  Int      @unique
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  /// Net Promoter Score 0-10
  score       Int
  comment     String?
  /// Optional category: speed, communication, price, packaging, other
  category    String?
  /// hash token mailed to client so only they can submit
  token       String   @unique
  submittedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([score])
  @@index([createdAt])
}

/// KPI and Activity tracking for Employees
model UserAction {
  id          Int      @id @default(autoincrement())
  userId      Int
  actionType  String   // e.g., 'CREATE_SHIPMENT', 'UPDATE_SHIPMENT'
  description String?
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

/// Railway stations for route planning and tariff calculation
model Station {
  id          Int      @id @default(autoincrement())
  /// Unique station code (e.g. "01002")
  code        String   @unique
  /// Station name in Uzbek
  nameUz      String
  /// Station name in Russian
  nameRu      String
  /// Station name in English
  nameEn      String
  /// Country name
  country     String   @default("O'zbekiston")
  /// Latitude
  lat         Float?
  /// Longitude
  lng         Float?
  /// Whether this is an active station
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leadsFrom   Lead[]   @relation("LeadFromStation")
  leadsTo     Lead[]   @relation("LeadToStation")

  @@index([code])
  @@index([country])
  @@index([active])
  @@index([nameUz])
  @@index([nameRu])
  @@index([nameEn])
}
