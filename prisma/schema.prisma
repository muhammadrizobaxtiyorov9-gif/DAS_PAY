// Prisma schema for DasPay logistics platform
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Lead/contact form submissions
model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  service   String?
  message   String
  ip        String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transportType String?
  fromStation   String?
  toStation     String?
  fromStationId Int?
  fromStationRef Station? @relation("LeadFromStation", fields: [fromStationId], references: [id])
  toStationId   Int?
  toStationRef   Station? @relation("LeadToStation", fields: [toStationId], references: [id])
  documents     Json?    @default("[]")
  assignedToId  Int?
  assignee      User?    @relation("UserLeads", fields: [assignedToId], references: [id])
  tasks         Task[]

  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([fromStationId])
  @@index([toStationId])
  @@index([status, createdAt])
}

/// Tracking queries for analytics
model TrackingQuery {
  id           Int      @id @default(autoincrement())
  trackingCode String
  ip           String?
  found        Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([trackingCode])
  @@index([createdAt])
}

/// Blog posts for content management
model BlogPost {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  titleUz     String
  titleRu     String
  titleEn     String
  contentUz   String
  contentRu   String
  contentEn   String
  excerptUz   String?
  excerptRu   String?
  excerptEn   String?
  image       String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
}

/// Shipment tracking data (mock data for demo)
model Shipment {
  id           Int      @id @default(autoincrement())
  trackingCode String   @unique
  senderName   String
  receiverName String
  origin       String
  destination  String
  status       String   @default("pending")
  weight       Float?
  description  String?
  events       Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clientPhone  String?
  client       Client?  @relation(fields: [clientPhone], references: [phone])
  
  originLat       Float?
  originLng       Float?
  destinationLat  Float?
  destinationLng  Float?
  currentLat      Float?
  currentLng      Float?
  routeSegments   Json     @default("[]")

  /// 'road' | 'rail' | 'air' | 'sea' — affects ETA avg speed
  transportMode   String?
  /// Total route distance in km (from OSRM or manual)
  distanceKm      Float?
  /// Projected delivery date/time
  etaAt           DateTime?
  /// Revenue captured on the shipment (from invoices or manual)
  revenue         Float    @default(0)
  /// Internal cost (carriers, fuel, customs) for margin calc
  cost            Float    @default(0)
  currency        String   @default("USD")

  /// Cargo type: bulk, container, liquid, perishable, oversized, general
  cargoType       String?
  /// One-time secret token used to scope QR-confirmation deep link
  receiveToken    String?  @unique
  /// Receiver's typed name on the QR confirmation page (digital signature)
  receivedSignature String?
  /// When the receiver scanned + confirmed delivery
  receivedAt      DateTime?
  /// Geolocation captured at confirmation
  receivedLat     Float?
  receivedLng     Float?
  /// Assigned employee responsible for status updates
  assignedToId    Int?
  assignedTo      User?    @relation("ShipmentAssignedTo", fields: [assignedToId], references: [id])
  /// Last time status was updated (for SLA monitoring)
  lastStatusUpdate DateTime?

  /// Multi-tenant branch scope
  branchId        Int?
  branch          Branch?  @relation(fields: [branchId], references: [id])

  createdById     Int?
  createdBy       User?    @relation("ShipmentsCreated", fields: [createdById], references: [id])
  invoices        Invoice[]
  feedback        Feedback?
  wagons          Wagon[]
  wagonMovements  WagonMovement[]
  trucks          Truck[]
  documents       ShipmentDocument[]

  @@index([trackingCode])
  @@index([status])
  @@index([createdById])
  @@index([clientPhone])
  @@index([assignedToId])
  @@index([branchId])
  @@index([branchId, status])
  @@index([branchId, createdAt])
  @@index([branchId, assignedToId])
}

/// Rate limiting for forms
model RateLimit {
  id        Int      @id @default(autoincrement())
  ip        String
  endpoint  String
  count     Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([ip, endpoint])
  @@index([windowStart])
}

/// Contract agreements with client companies
model Contract {
  id              Int      @id @default(autoincrement())
  /// Auto-incrementing contract number (e.g. 1, 2, 3...)
  contractNumber  Int      @unique @default(autoincrement())
  /// Date the contract was signed (e.g. "14 апрель 2026г")
  contractDate    String
  /// Client company name
  companyName     String
  /// Company director full name
  companyDirector String
  /// Company address
  companyAddress  String
  /// Company INN (9-digit, xxx xxx xxx)
  companyInn      String
  /// Serving bank name
  companyBank     String
  /// Bank MFO (5-digit)
  bankMfo         String
  /// Bank INN (9-digit)
  bankInn         String
  /// Bank account number
  bankNum         String
  /// Currency: UZS or USD
  bankCurrency    String   @default("UZS")
  /// Whether correspondent bank exists
  hasCorrespondent Boolean  @default(false)
  /// Correspondent bank name (optional)
  bankCorrName    String?
  /// Correspondent bank address (optional)
  bankCorrAddress String?
  /// Correspondent bank SWIFT code (optional)
  bankCorrSwift   String?
  /// Contract status
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        Invoice[]

  @@index([contractNumber])
  @@index([status])
  @@index([createdAt])
}

/// Freight tariff catalog — used by calculator and quick quotes
model Tariff {
  id             Int      @id @default(autoincrement())
  /// Human label e.g. "Xitoy → Toshkent (Avto)"
  name           String
  originCountry  String
  originCity     String?
  destCountry    String
  destCity       String?
  /// truck | train
  mode           String   @default("train")
  /// Price per ton in `currency`
  pricePerKg     Float    @default(0)
  /// Fixed baseline fee added to every shipment on this lane
  baseFee        Float    @default(0)
  /// Minimum billable weight (ton)
  minWeight      Float    @default(0)
  /// USD / UZS / RUB
  currency       String   @default("USD")
  /// Estimated transit time in days
  transitDays    Int?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  originStationId Int?
  originStation   Station? @relation("TariffOriginStation", fields: [originStationId], references: [id])
  destStationId   Int?
  destStation     Station? @relation("TariffDestStation", fields: [destStationId], references: [id])

  @@index([originCountry, destCountry])
  @@index([mode])
  @@index([active])
}

/// Invoice for a shipment / client
model Invoice {
  id           Int      @id @default(autoincrement())
  number       String   @unique
  issueDate    DateTime @default(now())
  dueDate      DateTime

  shipmentId   Int?
  shipment     Shipment? @relation(fields: [shipmentId], references: [id])

  clientPhone  String?
  client       Client?   @relation(fields: [clientPhone], references: [phone])

  contractId   Int?
  contract     Contract? @relation(fields: [contractId], references: [id])

  /// [{ description, quantity, unitPrice, total }]
  items        Json     @default("[]")
  subtotal     Float    @default(0)
  taxRate      Float    @default(0)
  tax          Float    @default(0)
  total        Float    @default(0)
  paidAmount   Float    @default(0)
  currency     String   @default("USD")

  /// draft, sent, paid, overdue, cancelled
  status       String   @default("draft")
  notes        String?

  sentAt       DateTime?
  paidAt       DateTime?

  /// Reminder cadence tracking — see lib/invoice-reminders.ts
  /// 0=none, 1=upcoming, 2=due-day, 3=overdue, 4=escalated
  lastReminderStage Int      @default(0)
  lastReminderAt    DateTime?

  createdById  Int?
  createdBy    User?    @relation("InvoicesCreated", fields: [createdById], references: [id])
  payments     Payment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([clientPhone])
  @@index([shipmentId])
  @@index([number])
  @@index([status, dueDate])
}

/// Admin/Employee users
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String?
  role        String   @default("ADMIN") // SUPERADMIN, ADMIN, ACCOUNTANT, DIRECTOR, DRIVER
  status      String   @default("ACTIVE")
  permissions Json?    @default("[]")
  /// Multi-tenant branch scope. Null = unscoped (SUPERADMIN or pre-migration legacy)
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actions   UserAction[]
  leads     Lead[]       @relation("UserLeads")
  tasksCreated  Task[] @relation("TasksCreated")
  tasksAssigned Task[] @relation("TasksAssigned")
  shipmentsCreated Shipment[] @relation("ShipmentsCreated")
  shipmentsAssigned Shipment[] @relation("ShipmentAssignedTo")
  invoicesCreated Invoice[]  @relation("InvoicesCreated")
  wagonsAssigned  Wagon[]    @relation("WagonAssignedTo")
  wagonStatusChanges WagonStatusLog[] @relation("WagonStatusChanges")
  trucksDriven    Truck[]    @relation("TruckDriver")
  truckStatusChanges TruckStatusLog[] @relation("TruckStatusChanges")
  slaViolations   SlaViolation[] @relation("SlaViolations")
  chatMessagesFrom ChatMessage[]   @relation("ChatFrom")
  chatMessagesTo   ChatMessage[]   @relation("ChatTo")
  clientMessages   ClientMessage[]

  @@index([username])
}

/// Task management for Employees
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  leadId      Int?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  assignedById Int
  assignedBy   User    @relation("TasksCreated", fields: [assignedById], references: [id])
  assignedToId Int
  assignedTo   User    @relation("TasksAssigned", fields: [assignedToId], references: [id])
  deadline     DateTime
  status       String  @default("pending")  // pending, in_progress, completed, overdue
  priority     String  @default("medium")   // low, medium, high, urgent
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([assignedToId])
  @@index([deadline])
}

/// Registered clients
model Client {
  id         Int        @id @default(autoincrement())
  phone      String     @unique
  telegramId String?    @unique
  name       String?
  companyName String?
  companyInn  String?
  language   String     @default("uz")
  otpCode    String?
  otpExpiry  DateTime?
  password   String?
  createdAt  DateTime   @default(now())

  /// Notification preferences
  notifyStatusChange  Boolean @default(true)
  notifyEta           Boolean @default(true)
  notifyInvoices      Boolean @default(true)
  notifyPromo         Boolean @default(false)
  notifyEmail         String?

  shipments  Shipment[]
  invoices   Invoice[]
  addresses  ClientAddress[]
  clientMessages ClientMessage[]

  @@index([phone])
  @@index([telegramId])
}

/// Saved sender/receiver addresses for a client (address book)
model ClientAddress {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// 'sender' or 'receiver'
  role        String
  label       String?
  fullName    String
  phone       String
  country     String
  city        String?
  address     String?
  notes       String?
  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, role])
}

/// Online payment attempts for invoices (Click, Payme, etc.)
model Payment {
  id          Int       @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  /// 'click' | 'payme' | 'manual'
  provider    String
  /// External transaction id from gateway
  externalId  String?   @unique
  amount      Float
  currency    String    @default("UZS")
  /// 'pending' | 'paid' | 'cancelled' | 'failed'
  status      String    @default("pending")
  /// Payload returned by gateway webhook (for audit)
  rawPayload  Json?

  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([invoiceId])
  @@index([status])
  @@index([provider, externalId])
}

/// Post-delivery NPS feedback tied to a shipment
model Feedback {
  id          Int      @id @default(autoincrement())
  shipmentId  Int      @unique
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  /// Net Promoter Score 0-10
  score       Int
  comment     String?
  /// Optional category: speed, communication, price, packaging, other
  category    String?
  /// hash token mailed to client so only they can submit
  token       String   @unique
  submittedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([score])
  @@index([createdAt])
}

/// KPI and Activity tracking for Employees
model UserAction {
  id          Int      @id @default(autoincrement())
  userId      Int
  actionType  String   // e.g., 'CREATE_SHIPMENT', 'UPDATE_SHIPMENT'
  description String?
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

/// Railway stations for route planning and tariff calculation
model Station {
  id          Int      @id @default(autoincrement())
  /// Unique station code (e.g. "01002")
  code        String   @unique
  /// Station name in Uzbek
  nameUz      String
  /// Station name in Russian
  nameRu      String
  /// Station name in English
  nameEn      String
  /// Country name
  country     String   @default("O'zbekiston")
  /// Latitude
  lat         Float?
  /// Longitude
  lng         Float?
  /// Whether this is an active station
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leadsFrom   Lead[]   @relation("LeadFromStation")
  leadsTo     Lead[]   @relation("LeadToStation")
  wagonsAtStation Wagon[] @relation("WagonAtStation")
  trucksAtStation Truck[] @relation("TruckAtStation")

  distancesFrom StationDistance[] @relation("DistanceFrom")
  distancesTo   StationDistance[] @relation("DistanceTo")
  movementsFrom WagonMovement[]   @relation("MovementFrom")
  movementsTo   WagonMovement[]   @relation("MovementTo")
  tariffsOrigin Tariff[]          @relation("TariffOriginStation")
  tariffsDest   Tariff[]          @relation("TariffDestStation")

  @@index([code])
  @@index([country])
  @@index([active])
  @@index([nameUz])
  @@index([nameRu])
  @@index([nameEn])
}

/// Global logistics partners displayed on the public site
model Partner {
  id        Int      @id @default(autoincrement())
  name      String
  logoUrl   String?
  color     String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([order])
}

/// Railway wagons with full lifecycle tracking
model Wagon {
  id        Int      @id @default(autoincrement())
  number    String   @unique
  type      String
  capacity  Float
  /// Lifecycle status: available, assigned, in_transit, at_station, returning, maintenance
  status    String   @default("available")
  
  /// Current location tracking
  currentLat  Float?
  currentLng  Float?
  lastLocationUpdate DateTime?
  
  /// Current station (if at a station)
  currentStationId Int?
  currentStation   Station? @relation("WagonAtStation", fields: [currentStationId], references: [id])
  
  /// Assigned employee responsible for updates
  assignedToId Int?
  assignedTo   User?  @relation("WagonAssignedTo", fields: [assignedToId], references: [id])
  
  /// Lock info: prevents reassignment without SuperAdmin
  lockedByShipmentId Int?
  lockedAt           DateTime?
  lockedByUserId     Int?

  /// Multi-tenant branch scope
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments  Shipment[]
  statusLogs WagonStatusLog[]
  movements  WagonMovement[]

  @@index([number])
  @@index([status])
  @@index([assignedToId])
  @@index([currentStationId])
  @@index([branchId])
  @@index([branchId, status])
}

/// Wagon status change history
model WagonStatusLog {
  id          Int      @id @default(autoincrement())
  wagonId     Int
  wagon       Wagon    @relation(fields: [wagonId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  lat         Float?
  lng         Float?
  note        String?
  changedById Int?
  changedBy   User?    @relation("WagonStatusChanges", fields: [changedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([wagonId])
  @@index([createdAt])
}

/// SLA violation tracking for KPI penalties
model SlaViolation {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation("SlaViolations", fields: [userId], references: [id])
  wagonId     Int?
  shipmentId  Int?
  /// WAGON_UPDATE_MISSED | SHIPMENT_UPDATE_MISSED
  type        String
  penalty     Int      @default(-3)
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// Road Trucks with full lifecycle tracking
model Truck {
  id        Int      @id @default(autoincrement())
  plateNumber String   @unique
  model      String
  capacity  Float
  /// Lifecycle status: available, assigned, in_transit, at_station, returning, maintenance, needs_repair
  status    String   @default("available")
  
  /// Current location tracking
  currentLat  Float?
  currentLng  Float?
  lastLocationUpdate DateTime?
  
  /// Current station (if at a station)
  currentStationId Int?
  currentStation   Station? @relation("TruckAtStation", fields: [currentStationId], references: [id])
  
  /// Assigned Driver
  driverId     Int?
  driver       User?  @relation("TruckDriver", fields: [driverId], references: [id])
  
  /// Lock info: prevents reassignment without SuperAdmin
  lockedByShipmentId Int?
  lockedAt           DateTime?
  lockedByUserId     Int?

  /// Multi-tenant branch scope
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments  Shipment[]
  statusLogs TruckStatusLog[]
  locationLogs TruckLocationLog[]

  @@index([plateNumber])
  @@index([status])
  @@index([driverId])
  @@index([currentStationId])
  @@index([branchId])
  @@index([branchId, status])
}

/// Truck status change history
model TruckStatusLog {
  id          Int      @id @default(autoincrement())
  truckId     Int
  truck       Truck    @relation(fields: [truckId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  lat         Float?
  lng         Float?
  note        String?
  changedById Int?
  changedBy   User?    @relation("TruckStatusChanges", fields: [changedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([truckId])
  @@index([createdAt])
}

/// Continuous location tracking for Yandex.Dostavka style map
model TruckLocationLog {
  id          Int      @id @default(autoincrement())
  truckId     Int
  truck       Truck    @relation(fields: [truckId], references: [id], onDelete: Cascade)
  shipmentId  Int?     // Optional, ties the log to a specific shipment
  
  lat         Float
  lng         Float
  speed       Float?   // km/h
  isStop      Boolean  @default(false) // True if speed is low for a sustained period
  
  createdAt   DateTime @default(now())

  @@index([truckId])
  @@index([shipmentId])
  @@index([createdAt])
}

/// In-app notifications for admin/driver users
model Notification {
  id          Int      @id @default(autoincrement())
  /// Target user (null = broadcast to all admins)
  userId      Int?
  /// 'lead' | 'shipment' | 'invoice' | 'sla' | 'driver' | 'system'
  type        String
  /// Short title
  title       String
  /// Detail message
  message     String
  /// Optional link to navigate to
  link        String?
  /// Whether the user has read this notification
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
  @@index([userId, isRead])
}

/// Anomaly events detected by background watchdog (geofence, GPS-loss, prolonged stop, etc.)
model AnomalyAlert {
  id          Int      @id @default(autoincrement())
  /// 'gps_lost' | 'long_stop' | 'off_route' | 'late_eta' | 'speed_limit'
  kind        String
  /// Primary entity types: 'shipment' | 'truck' | 'wagon'
  entityType  String
  entityId    Int
  /// Human-readable title
  title       String
  /// Body / context
  message     String
  /// JSON details (lat, lng, durationMin, distanceKm, etc.)
  meta        Json     @default("{}")
  /// 'open' | 'resolved' | 'snoozed'
  status      String   @default("open")
  /// Severity: 1=info, 2=warning, 3=critical
  severity    Int      @default(2)
  resolvedAt  DateTime?
  resolvedById Int?
  createdAt   DateTime @default(now())

  @@index([kind])
  @@index([status])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// Internal chat between admins/dispatchers and drivers (optionally tied to a shipment)
model ChatMessage {
  id          Int      @id @default(autoincrement())
  /// Author user (admin or driver)
  fromUserId  Int
  fromUser    User     @relation("ChatFrom", fields: [fromUserId], references: [id])
  /// Recipient user (admin or driver). 0 = none, but always set in 1-on-1 chats
  toUserId    Int
  toUser      User     @relation("ChatTo", fields: [toUserId], references: [id])
  /// Optional shipment context — chats tied to a specific shipment
  shipmentId  Int?
  /// Plain-text message body (max 2000 chars)
  body        String
  /// Optional attachment URL (uses /uploads/...)
  attachmentUrl String?
  /// Has the recipient seen this message?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([fromUserId, toUserId])
  @@index([toUserId, isRead])
  @@index([shipmentId])
  @@index([createdAt])
}

/// Support chat messages between Client and Admins
model ClientMessage {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id])
  /// Which admin is replying. Null if client sent it.
  adminId     Int?
  admin       User?    @relation(fields: [adminId], references: [id])
  isFromClient Boolean @default(true)
  body        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([createdAt])
}

/// Files attached to shipments — photos (loading/unloading) or scanned documents (CMR, TIR, TTN)
model ShipmentDocument {
  id          Int      @id @default(autoincrement())
  shipmentId  Int
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  /// 'photo' | 'cmr' | 'tir' | 'ttn' | 'invoice' | 'other'
  kind        String   @default("photo")
  /// Original file name as uploaded
  originalName String
  /// MIME type (image/jpeg, application/pdf, ...)
  mimeType    String
  /// Bytes
  size        Int
  /// Public URL or storage key
  url         String
  /// Optional caption
  caption     String?

  /// Who uploaded (admin/driver) or null = client-side
  uploadedById Int?
  /// Where the upload happened: 'driver' | 'admin' | 'client' | 'system'
  source       String   @default("admin")

  createdAt    DateTime @default(now())

  @@index([shipmentId])
  @@index([kind])
  @@index([createdAt])
}

/// Filial (branch) — multi-tenant scope unit. SUPERADMIN sees all; others see their own.
model Branch {
  id          Int      @id @default(autoincrement())
  /// Short code: TAS, BUX, SAM, etc.
  code        String   @unique
  /// Display name
  name        String
  /// City name
  city        String
  /// Optional address
  address     String?
  /// Branch contact phone
  phone       String?
  /// Branch manager user id (for routing)
  managerId   Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  trucks      Truck[]
  wagons      Wagon[]
  shipments   Shipment[]

  @@index([code])
  @@index([active])
}

/// Web Push subscriptions (PWA notifications)
model PushSubscription {
  id          Int      @id @default(autoincrement())
  /// Owner: admin/driver user OR client (one of must be set)
  userId      Int?
  clientId    Int?
  /// Browser endpoint URL (unique per device)
  endpoint    String   @unique
  /// p256dh public key from PushSubscription
  p256dh      String
  /// auth secret from PushSubscription
  auth        String
  /// User agent for debugging/listing devices
  userAgent   String?
  createdAt   DateTime @default(now())
  /// Last time a push attempt succeeded
  lastSuccess DateTime?
  /// Failure count (auto-prune at 5)
  failures    Int      @default(0)

  @@index([userId])
  @@index([clientId])
}

/// Ikki stansiya orasidagi masofa ma'lumotnomasi
model StationDistance {
  id            Int      @id @default(autoincrement())
  fromStationId Int
  toStationId   Int
  distanceKm    Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fromStation   Station  @relation("DistanceFrom", fields: [fromStationId], references: [id], onDelete: Cascade)
  toStation     Station  @relation("DistanceTo", fields: [toStationId], references: [id], onDelete: Cascade)

  @@unique([fromStationId, toStationId])
  @@index([fromStationId])
  @@index([toStationId])
}

/// Vagonning stansiyalar aro harakati (kunlik tezlik va bo'sh qatnov tahlili uchun)
model WagonMovement {
  id            Int      @id @default(autoincrement())
  wagonId       Int
  wagon         Wagon    @relation(fields: [wagonId], references: [id], onDelete: Cascade)
  
  fromStationId Int?
  fromStation   Station? @relation("MovementFrom", fields: [fromStationId], references: [id])
  toStationId   Int
  toStation     Station  @relation("MovementTo", fields: [toStationId], references: [id])
  
  shipmentId    Int?
  shipment      Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  isLoaded      Boolean  @default(false)
  distanceKm    Float    @default(0)
  
  startDate     DateTime @default(now())
  endDate       DateTime?
  
  // Avtomatik hisoblanadigan kunlik tezlik (km/day)
  averageDailyKm Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([wagonId])
  @@index([shipmentId])
  @@index([fromStationId])
  @@index([toStationId])
  @@index([isLoaded])
}
