# ========================================
# DasPay Environment Variables (Example)
# Copy this file to .env and fill in values
# ========================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/daspay

# Admin Panel Security
ADMIN_PASSWORD=your_secure_password
ADMIN_TOKEN_SECRET=your_long_random_secret_key

# Site
NEXT_PUBLIC_SITE_URL=https://das-pay.com
