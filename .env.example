# ===== DATABASE =====
DATABASE_URL=postgresql://daspay_user:YOUR_PASSWORD@localhost:5432/daspay_production

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_CHAT_ID="your_chat_id"

# ===== AUTHENTICATION =====
# CRITICAL: in production these MUST be ≥16 chars and unique. The app
# refuses to start if missing in NODE_ENV=production (see lib/secrets.ts).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN_SECRET="generate_with_openssl_rand_hex_32"
JWT_SECRET="generate_with_openssl_rand_hex_32"

# ===== CRON JOBS =====
# Used by /api/cron/sla-check and /api/cron/anomaly-check
CRON_SECRET="generate_with_openssl_rand_hex_32"

# ===== SITE =====
NEXT_PUBLIC_SITE_URL="https://das-pay.com"
BOT_WEB_APP_URL="https://das-pay.com"

# ===== SEO VERIFICATION =====
# Get these from webmaster tool dashboards (public tokens — safe to commit)
NEXT_PUBLIC_GOOGLE_VERIFICATION="YJ6i5QxvmEIKEikcrocVdLDwaeXvKfPjdfktZ7Qg4aU"
NEXT_PUBLIC_YANDEX_VERIFICATION="16f9215a2e6ec42e"
NEXT_PUBLIC_BING_VERIFICATION=""
NEXT_PUBLIC_FB_DOMAIN_VERIFICATION=""

# ===== ANALYTICS =====
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=""

# ===== AI (optional) =====
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
OPENAI_MAX_TOKENS="600"
OPENAI_TEMPERATURE="0.4"
AI_ENABLED="false"
CONV_MEMORY_TTL="86400"
CONV_MAX_MESSAGES="20"
REDIS_URL=""

# ===== EMAIL (optional) =====
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ===== PAYMENTS (optional) =====
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
PAYME_MERCHANT_ID=""
PAYMENTS_WEBHOOK_SECRET=""
FX_USD_UZS="12600"
FX_RUB_UZS="140"
FX_EUR_UZS="13800"

# ===== REVALIDATION =====
REVALIDATION_SECRET="random_secret_for_cache_revalidation"

# ===== WEB PUSH (PWA notifications) =====
# Generate with: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@das-pay.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
